# SnapShop Environment Variables
# Copy this file to .env and update values

# Database
DATABASE_URL=postgres://snapshop:snapshop123@localhost:5432/snapshop?sslmode=disable

# API
PORT=8080
JWT_SECRET=snapshop-jwt-secret-change-me

# PostgreSQL (Docker)
POSTGRES_DB=snapshop
POSTGRES_USER=snapshop
POSTGRES_PASSWORD=snapshop123
